APP_NAME=paste-king-app
APP_IMAGE=paste-king:latest
APP_CONTAINER_NAME=paste-king-app
SERVER_PORT=8080
APP_INITIAL_LOGIN=admin
APP_INITIAL_PASSWORD=change_me
APP_JWT_SECRET=change_this_to_a_random_32_plus_character_secret
APP_JWT_EXPIRATION=PT8H
APP_SWAGGER_ENABLED=false

NGINX_IMAGE=nginx:alpine
NGINX_CONTAINER_NAME=paste-king-nginx
NGINX_PORT=80
NGINX_INTERNAL_PORT=80
NGINX_API_RATE=10r/s
NGINX_API_BURST=30
NGINX_AUTH_RATE=5r/m
NGINX_AUTH_BURST=5
NGINX_CONNECTION_LIMIT=20

POSTGRES_IMAGE=postgres:16-alpine
POSTGRES_CONTAINER_NAME=paste-king-postgres
POSTGRES_HOST=postgres
POSTGRES_INTERNAL_PORT=5432
POSTGRES_DB=paste_king
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me
POSTGRES_VOLUME=paste-king-postgres-data
POSTGRES_HEALTHCHECK_INTERVAL=10s
POSTGRES_HEALTHCHECK_TIMEOUT=5s
POSTGRES_HEALTHCHECK_RETRIES=5
